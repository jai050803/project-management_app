generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())
  members   Member[]
  tasks     Task[]
}

model Member {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  tasks     Task[]   @relation("AssigneeTasks")
}

model Task {
  id           String       @id @default(cuid())
  title        String
  description  String
  status       TaskStatus   @default(TODO)
  priority     TaskPriority @default(MEDIUM)
  progress     Int          @default(0)
  deadline     DateTime?
  notes        String       @default("")
  dependencies String       @default("")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId    String
  assignee     Member?      @relation("AssigneeTasks", fields: [assigneeId], references: [id], onDelete: SetNull)
  assigneeId   String?
  attachments  Attachment[]
  updates      TaskUpdate[]
}

model Attachment {
  id        String   @id @default(cuid())
  type      String
  name      String
  url       String
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
}

model TaskUpdate {
  id        String   @id @default(cuid())
  author    String
  message   String
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

